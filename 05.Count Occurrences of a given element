public class CountOccurrences {
    public static void main(String[] args) {

        int[] arr = {2, 5, 3, 2, 8, 2, 7};
        int key = 2;
        int count = 0;

        for (int i = 0; i < arr.length; i++) {

            if (arr[i] == key) {
                count++;
            }
        }

        System.out.println("Element = " + key);
        System.out.println("Occurrences = " + count);
    }
}
